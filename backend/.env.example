# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openoptions
DB_USER=postgres
DB_PASSWORD=postgres

# Deribit (public API works without keys for read-only)
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# Tradier (get free sandbox key at https://developer.tradier.com)
TRADIER_TOKEN=

# FRED (get free key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Thresholds
VOL_THRESHOLD=2.0

# General
ENVIRONMENT=development
MARKET_TZ=America/New_York
